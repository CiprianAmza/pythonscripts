### 67.3. Schema de chei (KeyspaceLayout)

```java
public final class KeyspaceLayout {
    private KeyspaceLayout() {}

    // Subspaces principali
    public static final String USERS = "u";
    public static final String ORDERS = "o";
    public static final String PAYMENTS = "p";
    public static final String AUDIT = "audit";
    public static final String IDEMPOTENCY = "idem";

    // Indexuri
    public static final String IDX_USER_EMAIL = "idx_ue";
    public static final String IDX_USER_STATUS = "idx_us";
    public static final String IDX_ORDER_CUSTOMER = "idx_oc";
    public static final String IDX_ORDER_STATUS = "idx_os";
    public static final String IDX_PAYMENT_STATUS = "idx_ps";

    public static byte[] userProfileKey(String tenantId, String userId) {
        return Tuple.from(USERS, tenantId, userId, "profile").pack();
    }

    public static byte[] userEmailIndexKey(String tenantId, String emailLower) {
        return Tuple.from(IDX_USER_EMAIL, tenantId, emailLower).pack();
    }

    public static byte[] userStatusIndexKey(String tenantId, String status, String userId) {
        return Tuple.from(IDX_USER_STATUS, tenantId, status, userId).pack();
    }

    public static byte[] orderKey(String tenantId, String orderId) {
        return Tuple.from(ORDERS, tenantId, orderId).pack();
    }

    public static byte[] orderCustomerIndexKey(String tenantId, String customerId,
                                                long createdAtMillis, String orderId) {
        return Tuple.from(IDX_ORDER_CUSTOMER, tenantId, customerId, createdAtMillis, orderId).pack();
    }

    public static byte[] orderStatusIndexKey(String tenantId, String status, String orderId) {
        return Tuple.from(IDX_ORDER_STATUS, tenantId, status, orderId).pack();
    }

    public static byte[] paymentKey(String tenantId, String paymentId) {
        return Tuple.from(PAYMENTS, tenantId, paymentId).pack();
    }

    public static byte[] paymentStatusIndexKey(String tenantId, String status, String paymentId) {
        return Tuple.from(IDX_PAYMENT_STATUS, tenantId, status, paymentId).pack();
    }

    public static byte[] auditKey(String tenantId, long timestampMillis, String eventId) {
        return Tuple.from(AUDIT, tenantId, timestampMillis, eventId).pack();
    }

    public static byte[] idempotencyKey(String tenantId, String key) {
        return Tuple.from(IDEMPOTENCY, tenantId, key).pack();
    }
}
```

### 67.4. UserService (extras)

```java
@Service
public class UserService {
    private final Database db;
    private final ObjectMapper mapper;
    private final FdbMetrics metrics;

    public String registerUser(String tenantId, String email, String name) {
        String userId = UUID.randomUUID().toString();
        Instant now = Instant.now();

        return metrics.timeTransaction("user_register", () ->
            db.run(tr -> {
                String emailLower = email.toLowerCase(Locale.ROOT);
                byte[] emailIdxKey = KeyspaceLayout.userEmailIndexKey(tenantId, emailLower);

                byte[] existing = tr.get(emailIdxKey).join();
                if (existing != null) {
                    throw new DuplicateEmailException(email);
                }

                User user = new User(userId, email, name, "ACTIVE", now);
                tr.set(KeyspaceLayout.userProfileKey(tenantId, userId), serialize(user));
                tr.set(emailIdxKey, userId.getBytes(StandardCharsets.UTF_8));
                tr.set(KeyspaceLayout.userStatusIndexKey(tenantId, "ACTIVE", userId),
                    new byte[0]);

                tr.set(KeyspaceLayout.auditKey(tenantId, now.toEpochMilli(),
                    UUID.randomUUID().toString()),
                    serialize(new AuditEntry("USER_REGISTERED", userId,
                        Map.of("email", email))));

                return userId;
            })
        );
    }
}
```

### 67.5. PaymentService cu idempotency

```java
@Service
public class PaymentService {
    private final Database db;
    private final PaymentProvider provider;

    public PaymentResult processPayment(String tenantId, String orderId,
                                         BigDecimal amount, String idempotencyKey) {
        // 1. Verifică idempotency
        PaymentResult cached = db.run(tr -> {
            byte[] key = KeyspaceLayout.idempotencyKey(tenantId, idempotencyKey);
            byte[] raw = tr.get(key).join();
            return raw == null ? null : deserialize(raw, PaymentResult.class);
        });
        if (cached != null) return cached;

        // 2. Apel extern, în afara retry loop-ului
        PaymentResult fresh = provider.charge(orderId, amount, idempotencyKey);

        // 3. Persistă rezultatul tranzacțional
        db.run(tr -> {
            tr.set(KeyspaceLayout.idempotencyKey(tenantId, idempotencyKey), serialize(fresh));
            if (fresh.isSuccess()) {
                Payment payment = new Payment(fresh.getPaymentId(), orderId, amount,
                    "COMPLETED", Instant.now());
                tr.set(KeyspaceLayout.paymentKey(tenantId, payment.getId()),
                    serialize(payment));
                tr.set(KeyspaceLayout.paymentStatusIndexKey(tenantId, "COMPLETED",
                    payment.getId()), new byte[0]);
            }
            tr.set(KeyspaceLayout.auditKey(tenantId, Instant.now().toEpochMilli(),
                UUID.randomUUID().toString()),
                serialize(new AuditEntry("PAYMENT_PROCESSED", orderId,
                    Map.of("amount", amount.toString(),
                           "success", String.valueOf(fresh.isSuccess())))));
            return null;
        });

        return fresh;
    }
}
```

