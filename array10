let vals = ["A", "B", "C", "D"];
let ind = 0;

function array10() {
  
  let ANS = [];

  for (let r = 0; r < 10; r++) {
    
    let row = [];
    for (let c = 0; c < 10; c++)
      row.push(vals[(r + c) % 4]);
    ANS.push(row);
  }

  ANS[0][0] = vals[ind % 4];
  ANS[0][1] = vals[Math.floor(ind / 4) % 4];
  ANS[0][2] = vals[Math.floor(ind / 16) % 4];
  ANS[0][3] = vals[Math.floor(ind / 64) % 4];

  ind++;

  return ANS;
}
