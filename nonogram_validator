class Nonogram:
    
    def __init__(self, clues):
        
        self.clues = clues 
        self.rows, self.cols = [clue for line in clues[1] for clue in line], [clue for line in clues[0] for clue in line]
        
    def check(self, grid):
        
        if not self.check_if_clues_and_grid_have_same_length(1, grid) or not self.check_if_clues_and_grid_have_same_length(0, grid):
            return False
        if not self.validate_values_for_given_clues(grid, self.rows):
            return False
        if not self.validate_values_for_given_clues([*map(list, zip(*grid))], self.cols):
            return False
        
        return True
        
                    
    def check_if_clues_and_grid_have_same_length(self, i, grid):
        
        length = len(grid)
        if len(self.clues[i]) != length:
            return False
    
        return all(len(entry) <= length for entry in self.clues[i])
    
    def validate_values_for_given_clues(self, grid, clues):
        
        values = []
        for row in grid:
            cur, count = "", 0
            for element in row + ["."]:
                if element == cur:
                    count += 1
                else:
                    if cur == 1:
                        values.append(count)
                    cur = element
                    count = 1

        return values == clues
